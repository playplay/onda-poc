# Database (local dev — Vercel auto-injects POSTGRES_URL in production)
DATABASE_URL=postgresql+asyncpg://scraptrends:scraptrends@localhost:5432/scraptrends

# Apify
APIFY_TOKEN=your_apify_token_here

# Anthropic (post performance analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vercel AI Gateway (Gemini 2.5 Flash)
AI_GATEWAY_API_KEY=your_ai_gateway_api_key_here
# OIDC token - run 'vercel env pull' to get it (expires every 12h)
VERCEL_OIDC_TOKEN=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
