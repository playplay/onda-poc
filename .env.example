# Database (local dev — Vercel auto-injects POSTGRES_URL in production)
DATABASE_URL=postgresql+asyncpg://user@localhost:5432/onda

# Scraping APIs
APIFY_TOKEN=your_apify_token_here
API_BRIGHT_DATA=your_bright_data_api_key_here

# AI
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Auth — legacy single-user (fallback if USERS is empty)
AUTH_EMAIL=admin@example.com
AUTH_PASSWORD=changeme

# Auth — multi-user JSON array
# USERS=[{"email":"alice@example.com","password":"secret","name":"Alice","role":"user"},{"email":"admin@example.com","password":"secret","name":"Admin","role":"admin"}]

# JWT
JWT_SECRET=generate-with-openssl-rand-hex-32

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
